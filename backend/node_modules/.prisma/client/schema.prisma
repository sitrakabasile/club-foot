// ============================================================
// NEXT-GEN FOOTBALL HUB — Prisma Schema
// Covers: Users, Profiles, Players, Teams, Matches, Statistics,
//         Medical Records, Contracts, Shop, Orders, Tickets,
//         News, Loyalty, and Training.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

// Using SQLite for local development. Switch to MySQL for production:
// provider = "mysql"
// url = "mysql://user:password@localhost:3306/nextgen_football"
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS (modeled as strings for SQLite compatibility) ----------

// Role: ADMIN | STAFF | PLAYER | FAN
// PlayerPosition: GK | CB | LB | RB | CDM | CM | CAM | LW | RW | ST
// PlayerStatus: ACTIVE | INJURED | SUSPENDED | ON_LOAN | RETIRED
// MatchStatus: SCHEDULED | LIVE | COMPLETED | POSTPONED | CANCELLED
// OrderStatus: PENDING | CONFIRMED | SHIPPED | DELIVERED | CANCELLED
// TicketStatus: AVAILABLE | RESERVED | SOLD | USED | CANCELLED
// TeamCategory: SENIOR | RESERVE | U21 | U18 | U15 | WOMEN

// ---------- USER & AUTH ----------

/// User account with role-based access control.
/// Links to Profile (personal info) and optional Player record.
model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String // bcrypt hashed
  role             String   @default("FAN") // ADMIN, COACH, PLAYER, MEDICAL, FAN
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  pointsFidelite   Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  profile        Profile?
  sessions       Session[]
  orders         Order[]
  tickets        Ticket[]
  loyaltyHistory LoyaltyTransaction[]
  newsArticles   News[]               @relation("AuthoredNews")
  finances       Finance[] // Finances associated with the user/staff

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

/// User profile with personal information.
/// Separated from User to keep auth data clean.
model Profile {
  id        String    @id @default(cuid())
  firstName String // prénom
  lastName  String // nom
  photo     String? // URL to profile image
  phone     String?
  birthDate DateTime?
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ---------- TEAM & PLAYERS ----------

/// Football team/squad (Senior, U21, Women, etc.)
model Team {
  id        String   @id @default(cuid())
  name      String // e.g., "Équipe Première"
  category  String // SENIOR, RESERVE, U21, U18, U15, WOMEN
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  players     Player[]
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")

  @@map("teams")
}

/// Player profile linked to a user and a team.
/// Contains position, jersey number, and current status.
model Player {
  id           String   @id @default(cuid())
  name         String // Full name (Mbappé, etc.)
  position     String // GK, CB, LB, RB, CDM, CM, CAM, LW, RW, ST
  number       Int // Jersey number
  status       String   @default("ACTIVE") // ACTIVE, INJURED, SUSPENDED, ON_LOAN, RETIRED
  height       Float? // cm
  weight       Float? // kg
  foot         String? // LEFT, RIGHT, BOTH
  nationality  String?
  marketValue  Float? // Estimated market value in EUR
  trainingLoad Int      @default(0) // 0-100 fatigue/load level
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  teamId         String
  team           Team                 @relation(fields: [teamId], references: [id])
  statistics     Statistics[]
  medicalRecords MedicalRecord[]
  contracts      Contract[]
  trainings      TrainingAttendance[]

  @@map("players")
}

// ---------- MATCHES & STATISTICS ----------

/// A football match with home/away teams and scores.
model Match {
  id          String   @id @default(cuid())
  date        DateTime
  venue       String // Stadium name
  competition String? // e.g., "Ligue 1", "Coupe de France"
  status      String   @default("SCHEDULED") // SCHEDULED, LIVE, COMPLETED, POSTPONED
  scoreHome   Int      @default(0)
  scoreAway   Int      @default(0)
  attendance  Int? // Number of spectators
  referee     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  homeTeamId String
  homeTeam   Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId String
  awayTeam   Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  statistics Statistics[]
  tickets    Ticket[]

  @@map("matches")
}

/// Individual player statistics for a specific match.
model Statistics {
  id            String   @id @default(cuid())
  goals         Int      @default(0)
  assists       Int      @default(0)
  minutesPlayed Int      @default(0)
  yellowCards   Int      @default(0)
  redCards      Int      @default(0)
  saves         Int      @default(0) // For goalkeepers
  passAccuracy  Float? // Percentage
  distance      Float? // km covered
  rating        Float? // Match rating (1-10)
  createdAt     DateTime @default(now())

  // Relations
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([playerId, matchId]) // One stat record per player per match
  @@map("statistics")
}

// ---------- MEDICAL ----------

/// Medical record tracking injuries, diagnoses, and recovery timelines.
model MedicalRecord {
  id           String    @id @default(cuid())
  type         String // INJURY, ILLNESS, SURGERY, CHECKUP
  diagnosis    String
  description  String?
  severity     String? // MINOR, MODERATE, SEVERE
  dateOccurred DateTime
  dateReturn   DateTime? // Expected return date
  actualReturn DateTime? // Actual return date
  treatment    String?
  doctor       String? // Attending physician
  isCleared    Boolean   @default(false) // Cleared to play
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("medical_records")
}

// ---------- FINANCES ----------

model Finance {
  id        String   @id @default(cuid())
  type      String // INCOME | EXPENSE
  amount    Float
  label     String // libelle
  category  String? // SPONSORSHIP, SALARY, SHOP, TICKETS
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("finances")
}

// ---------- CONTRACTS ----------

/// Player contract with financial details and duration.
model Contract {
  id            String   @id @default(cuid())
  type          String   @default("PLAYER") // PLAYER, STAFF, SPONSOR
  salary        Float // Monthly salary in EUR
  bonuses       Float? // Performance bonuses
  releaseClause Float? // Release clause value
  startDate     DateTime
  endDate       DateTime
  status        String   @default("ACTIVE") // ACTIVE, EXPIRED, TERMINATED
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  playerId String
  player   Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  finances Finance[]

  @@map("contracts")
}

// ---------- TRAINING ----------

/// Training session record.
model Training {
  id        String   @id @default(cuid())
  date      DateTime
  type      String // TACTICAL, PHYSICAL, RECOVERY, MATCH_PREP
  duration  Int // Duration in minutes
  location  String?
  coach     String?
  notes     String?
  intensity String? // LOW, MEDIUM, HIGH
  createdAt DateTime @default(now())

  // Relations
  attendances TrainingAttendance[]

  @@map("trainings")
}

/// Tracks which players attended which training sessions.
model TrainingAttendance {
  id          String   @id @default(cuid())
  present     Boolean  @default(true)
  performance String? // Rating or notes
  createdAt   DateTime @default(now())

  // Relations
  playerId   String
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([playerId, trainingId])
  @@map("training_attendances")
}

// ---------- E-COMMERCE (BOUTIQUE) ----------

/// Shop article (jersey, merchandise, etc.)
model Article {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  image       String?
  category    String? // JERSEY, SCARF, ACCESSORY, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orderItems OrderItem[]

  @@map("articles")
}

/// Customer order from the online shop.
model Order {
  id              String   @id @default(cuid())
  total           Float
  status          String   @default("PENDING") // PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED
  shippingAddress String?
  paymentMethod   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  userId String
  user   User        @relation(fields: [userId], references: [id])
  items  OrderItem[]

  @@map("orders")
}

/// Individual item in an order.
model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  unitPrice Float
  size      String? // S, M, L, XL, XXL (for jerseys)
  createdAt DateTime @default(now())

  // Relations
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  articleId String
  article   Article @relation(fields: [articleId], references: [id])

  @@map("order_items")
}

// ---------- BILLETTERIE (TICKETS) ----------

/// Match ticket for fans.
model Ticket {
  id          String    @id @default(cuid())
  section     String? // Tribune Nord, VIP, etc.
  seat        String? // Row/Seat number
  price       Float
  status      String    @default("AVAILABLE") // AVAILABLE, RESERVED, SOLD, USED, CANCELLED
  qrCode      String?   @unique // QR code string for entry
  purchasedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  matchId String
  match   Match   @relation(fields: [matchId], references: [id])
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])

  @@map("tickets")
}

// ---------- NEWS & CONTENT ----------

/// News article for the fan zone.
model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String // Rich text / Markdown
  excerpt     String?
  coverImage  String?
  category    String? // MATCH_REPORT, TRANSFER, INTERVIEW, etc.
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  authorId String
  author   User   @relation("AuthoredNews", fields: [authorId], references: [id])

  @@map("news")
}

// ---------- LOYALTY PROGRAM ----------

/// Tracks loyalty points transactions (earn/spend).
model LoyaltyTransaction {
  id          String   @id @default(cuid())
  points      Int // Positive = earned, negative = spent
  type        String // PURCHASE, ATTENDANCE, REFERRAL, REDEMPTION
  description String?
  createdAt   DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("loyalty_transactions")
}
